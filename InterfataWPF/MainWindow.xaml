<Window x:Class="InterfataWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Management Cursanți - WPF" Height="700" Width="1100"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Culori principale: Mov/Blue (Indigo) pe fundal luminos -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>

        <!-- Stil global Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stil global TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stil global RadioButton & CheckBox -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Stil Label-uri informative -->
        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- Stil ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="350"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="2*" MinWidth="450"/>
            </Grid.ColumnDefinitions>

            <!-- Panoul din stânga: Căutare și Listă -->
            <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Cursanți" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                    
                    <!-- Căutare -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtCauta" Grid.Column="0" ToolTip="Caută după nume..."/>
                        <Button x:Name="btnCauta" Grid.Column="2" Content="Caută" Click="BtnCauta_Click"/>
                    </Grid>

                    <ListBox x:Name="lstCursanti" Grid.Row="2" 
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="LstCursanti_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Nume}" FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Nivel}" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Panoul din dreapta: Detalii și Formular -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Detalii Cursant Selectat -->
                <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>

                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Detalii Cursant (Editabil)" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Button x:Name="btnSterge" Content="Delete" Click="BtnSterge_Click" Background="#EF4444" Foreground="White" Padding="15,5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lblNume" Text="Selectează un cursant" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        
                        <Grid x:Name="gridEditareDetalii" IsEnabled="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="NIVEL Curs" Style="{StaticResource CardLabelStyle}"/>
                                <ComboBox x:Name="cmbEditNivel" Padding="5" Margin="0,5,0,0">
                                    <ComboBoxItem Content="Începător"/>
                                    <ComboBoxItem Content="Intermediar"/>
                                    <ComboBoxItem Content="Avansat"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="ȘEDINȚE RĂMASE" Style="{StaticResource CardLabelStyle}"/>
                                <TextBox x:Name="txtEditSedinte" Padding="5" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="OPȚIUNI" Style="{StaticResource CardLabelStyle}"/>
                                <StackPanel Orientation="Vertical" Margin="0,5,0,0">
                                    <CheckBox x:Name="chkEditOnline" Content="Online"/>
                                    <CheckBox x:Name="chkEditWeekend" Content="Weekend" Margin="0,3,0,0"/>
                                    <CheckBox x:Name="chkEditFizic" Content="Fizic" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        
                        <Button x:Name="btnUpdate" Content="Salvează Modificări" Click="BtnUpdate_Click" HorizontalAlignment="Right" Margin="0,15,0,0" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <!-- Formular Adăugare -->
                <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Adaugă Cursant" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                    <TextBlock Text="Nume și Prenume" Style="{StaticResource CardLabelStyle}"/>
                                    <TextBox x:Name="txtNume" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Număr Ședințe (Sold)" Style="{StaticResource CardLabelStyle}"/>
                                    <TextBox x:Name="txtSedinte" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Radio Buttons pentru Nivel -->
                                <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                    <TextBlock Text="Nivel Curs" Style="{StaticResource CardLabelStyle}"/>
                                    <StackPanel Orientation="Vertical">
                                        <RadioButton x:Name="rbIncepator" Content="Începător" IsChecked="True" Margin="0,5,0,0"/>
                                        <RadioButton x:Name="rbIntermediar" Content="Intermediar" Margin="0,5,0,0"/>
                                        <RadioButton x:Name="rbAvansat" Content="Avansat" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- CheckBoxes pentru Optiuni -->
                                <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Opțiuni Suplimentare" Style="{StaticResource CardLabelStyle}"/>
                                    <StackPanel Orientation="Vertical">
                                        <CheckBox x:Name="chkOnline" Content="Online" Margin="0,5,0,0"/>
                                        <CheckBox x:Name="chkWeekend" Content="Weekend" Margin="0,5,0,0"/>
                                        <CheckBox x:Name="chkFizic" Content="Fizic" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="lblMesajEroare" Text="" Foreground="#EF4444" FontSize="14" Margin="0,10,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                <Button x:Name="btnReset" Content="Resetare Formular" Click="BtnReset_Click" Background="#F1F5F9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                                <Button x:Name="btnAdauga" Content="Salvează Cursant" Click="BtnAdauga_Click" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
    </Grid>
</Window>
